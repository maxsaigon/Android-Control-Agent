<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Network permissions for WebSocket server -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <uses-permission android:name="android.permission.ACCESS_WIFI_STATE" />

    <!-- Foreground service to keep alive -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />

    <!-- Query installed packages -->
    <uses-permission android:name="android.permission.QUERY_ALL_PACKAGES" />

    <!-- Boot completed to auto-start -->
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />

    <application
        android:allowBackup="true"
        android:icon="@android:drawable/ic_menu_manage"
        android:label="AC Helper"
        android:supportsRtl="true">

        <!-- Main Activity — minimal UI for status -->
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:label="AC Helper">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Accessibility Service — core automation engine -->
        <service
            android:name=".HelperAccessibilityService"
            android:exported="false"
            android:permission="android.permission.BIND_ACCESSIBILITY_SERVICE">
            <intent-filter>
                <action android:name="android.accessibilityservice.AccessibilityService" />
            </intent-filter>
            <meta-data
                android:name="android.accessibilityservice"
                android:resource="@xml/accessibility_config" />
        </service>

        <!-- WebSocket Foreground Service -->
        <service
            android:name=".WebSocketService"
            android:exported="false"
            android:foregroundServiceType="connectedDevice" />

        <!-- Boot receiver -->
        <receiver
            android:name=".BootReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
            </intent-filter>
        </receiver>

    </application>
</manifest>
